# ============================================
# College Placement Portal - Environment Config
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# For local MongoDB use: mongodb://127.0.0.1:27017/college_placement_portal
# For MongoDB Atlas use your Atlas connection string below:
MONGODB_URI=mongodb://127.0.0.1:27017/college_placement_portal

# JWT Secret & Expiry
JWT_SECRET=super_secret_jwt_key_change_this_in_production_1234567890
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Client URL (used for CORS)
CLIENT_URL=http://localhost:5173

# File Upload Limit (in MB)
MAX_FILE_SIZE=5

# Email (Used for sending password reset / notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=College Placement Portal <no-reply@placementportal.com>
